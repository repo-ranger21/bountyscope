# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ── Researcher config ──────────────────────────────────────────
# Options: standard | resourceful | 1337
RESEARCHER_TIER=standard

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── WPScan API (free tier: 25 req/day) ────────────────────────
# Get token: https://wpscan.com/register
WPSCAN_API_TOKEN=

# ── Patchstack API (free tier: 100 req/day) ───────────────────
# Get token: https://patchstack.com/register
# Critical: Patchstack indexes benzdeus-style findings BEFORE Wordfence.
# Without this, you will miss CVEs like WCFM CVE-2025-64631.
PATCHSTACK_API_TOKEN=
